# ── Cloudinary（图片存储，免费账号即可）──────────────────────────
# 注册地址：https://cloudinary.com/
# 在 Dashboard → Settings → Upload → Upload presets 创建一个 Unsigned preset
TARO_APP_CLOUDINARY_CLOUD_NAME=填你的cloud_name
TARO_APP_CLOUDINARY_UPLOAD_PRESET=填你的upload_preset

# ── Supabase（数据库，免费账号即可）──────────────────────────────
# 注册地址：https://supabase.com/
# 在 Project Settings → API 里找到 Project URL 和 anon key
TARO_APP_SUPABASE_URL=https://填你的project_id.supabase.co
TARO_APP_SUPABASE_ANON_KEY=填你的anon_key
